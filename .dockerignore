# Dependencies / build artefacts — rebuilt inside the image, never copied from host
/node_modules
/vendor
/.output
/.nuxt
/.data
/.nitro
/.cache
/public/build

# VCS / local tooling
/.git
/.github
/.idea
/.vscode
/.fleet
/.zed

# Env & secrets
.env
.env.*
!.env.example

# Logs & local state
/storage/logs/*
/storage/framework/cache/*
/storage/framework/sessions/*
/storage/framework/views/*
npm-debug.log
yarn-error.log

# Tests / docs not needed in the runtime image
/.phpunit.cache
/.phpunit.result.cache
